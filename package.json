{
  "name": "xdraw",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Excalidraw CLI that opens files in your system browser",
  "type": "module",
  "packageManager": "bun@1.3.0",
  "bin": {
    "xdraw": "./bin/xdraw.ts"
  },
  "scripts": {
    "build": "bun build --target=bun --root . --outdir dist ./bin/xdraw.ts",
    "build:exe": "bun build --compile --root . ./bin/xdraw.ts --outfile dist/xdraw",
    "compile": "bun build --compile --root . ./bin/xdraw.ts --outfile dist/xdraw",
    "dev": "bun --hot ./bin/xdraw.ts",
    "start": "./bin/xdraw.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "excalidraw",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "bun-types": "^1.3.0",
    "typescript": "^5.9.3"
  }
}
